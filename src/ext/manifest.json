{
  "manifest_version": 3,
  "name": "LLM Architecture & VRAM Calculator",
  "version": "1.0.0",
  "description": "Zero-download model topology parsing with verified KV Cache Profiles for GLM 5.2, DeepSeek V4 Pro, and Hy3.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://huggingface.co/*",
    "https://cdn-lfs.huggingface.co/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LLM Architecture & VRAM Calculator"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
